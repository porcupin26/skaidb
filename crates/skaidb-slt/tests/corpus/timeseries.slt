query I
SELECT count(*) FROM m2
----
601

# --- Unbounded LIMIT walks (v0.138.2/.3): oldest-n and latest-n with no
# time bound anchor at the data frontier — the ASC form had no fast path
# at all, and both fell back to a full-range gather (scan-budget death on
# big tables; the walk-engagement proof lives in the Rust tests, the
# result semantics here).

query IR
SELECT ts, value FROM m2 ORDER BY ts LIMIT 2
----
1000 0.000
2000 1.000

query IR
SELECT ts, value FROM m2 ORDER BY ts DESC LIMIT 2
----
100000000 999.000
600000 599.000
