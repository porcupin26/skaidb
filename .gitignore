# Private / local-only files — never commit
claude.start
.priv/

# LLM / agent artifacts — never commit
.claude/
.claude*
*.llm
CLAUDE.md

# Rust
/target/
**/*.rs.bk
# Cargo.lock IS committed: skaidb ships binaries, so lockfile reproducibility matters.

# Standalone example projects build their own target/ and don't ship —
# their Cargo.lock is regenerated on demand, unlike the workspace's.
examples/rust/target/
examples/rust/Cargo.lock
examples/vectors/rust/target/
examples/vectors/rust/Cargo.lock
examples/java/out/

# Release packaging scratch (produced by nfpm in CI / local builds)
/dist/
/staging/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Python bytecode
__pycache__/
*.pyc
